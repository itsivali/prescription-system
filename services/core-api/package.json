{
  "name": "@hospital-crm/core-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run prisma:generate && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "PRISMA_SCHEMA_ENGINE_BINARY=.prisma-engines/schema-engine PRISMA_QUERY_ENGINE_LIBRARY=.prisma-engines/libquery_engine.so.node PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma generate",
    "prisma:migrate": "PRISMA_SCHEMA_ENGINE_BINARY=.prisma-engines/schema-engine PRISMA_QUERY_ENGINE_LIBRARY=.prisma-engines/libquery_engine.so.node PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma migrate dev",
    "prisma:deploy": "PRISMA_SCHEMA_ENGINE_BINARY=.prisma-engines/schema-engine PRISMA_QUERY_ENGINE_LIBRARY=.prisma-engines/libquery_engine.so.node PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma migrate deploy",
    "prisma:studio": "PRISMA_SCHEMA_ENGINE_BINARY=.prisma-engines/schema-engine PRISMA_QUERY_ENGINE_LIBRARY=.prisma-engines/libquery_engine.so.node PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 prisma studio",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "argon2": "^0.40.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "pdfkit": "^0.18.0",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pdfkit": "^0.17.6",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
