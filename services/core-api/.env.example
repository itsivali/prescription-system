# Copy to .env (or rely on the Nix shellHook for local dev).
NODE_ENV=development
PORT=8080

DATABASE_URL=postgresql://hospital:hospital_dev@localhost:5433/hospital_crm
REDIS_URL=redis://127.0.0.1:6380

# RSA keypair used to sign prescription QR JWTs. The Nix shellHook generates
# this automatically on first entry; in production load from a secrets manager.
JWT_PRIVATE_KEY_PATH=../.secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=../.secrets/jwt_public.pem

# Symmetric secret for session/access tokens. >=32 chars. Rotate periodically.
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000

# Comma-separated origins for CORS. Empty = CORS disabled.
CORS_ORIGINS=http://localhost:5173
